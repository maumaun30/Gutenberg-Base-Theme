{
  "apiVersion": 3,
  "name": "mytheme/post-archive",
  "title": "Post Archive",
  "category": "design",
  "icon": "grid-view",
  "description": "Displays a grid of posts or custom post types with Load More support.",
  "editorScript": "file:./build/index.js",
  "style": "file:./style.css",
  "render": "file:./render.php",
  "attributes": {
    "sectionLabel": {
      "type": "string",
      "default": "All Blogs"
    },
    "postType": {
      "type": "string",
      "default": "posts"
    },
    "postsPerPage": {
      "type": "number",
      "default": 4
    },
    "showLoadMore": {
      "type": "boolean",
      "default": true
    },
    "columns": {
      "type": "number",
      "default": 2
    }
  }
}