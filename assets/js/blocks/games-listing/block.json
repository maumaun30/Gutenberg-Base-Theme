{
  "apiVersion": 3,
  "name": "mytheme/games-listing",
  "title": "Games Listing",
  "category": "design",
  "icon": "block-default",
  "description": "Displays games from the Game CPT grouped by game_category taxonomy.",
  "editorScript": "file:./build/index.js",
  "style": "file:./style.css",
  "render": "file:./render.php",
  "attributes": {
    "postsPerCategory": {
      "type": "number",
      "default": 6
    },
    "showViewAll": {
      "type": "boolean",
      "default": true
    },
    "selectedCategories": {
      "type": "array",
      "default": [],
      "items": { "type": "number" }
    },
    "categoryOrder": {
      "type": "array",
      "default": [],
      "items": { "type": "number" }
    }
  }
}