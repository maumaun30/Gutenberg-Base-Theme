{
  "apiVersion": 3,
  "name": "mytheme/hero",
  "title": "Hero",
  "category": "design",
  "icon": "block-default",
  "description": "Hero banner block with dynamic breadcrumbs and post type image grid.",
  "editorScript": "file:./build/index.js",
  "style": "file:./style.css",
  "render": "file:./render.php",
  "attributes": {
    "title": {
      "type": "string",
      "default": "Hero Title"
    },
    "subtitle": {
      "type": "string",
      "default": ""
    },
    "breadcrumbLabel": {
      "type": "string",
      "default": ""
    },
    "ctaText": {
      "type": "string",
      "default": "Register Now"
    },
    "ctaUrl": {
      "type": "string",
      "default": "#"
    },
    "selectedPostType": {
      "type": "string",
      "default": "post"
    },
    "imageCount": {
      "type": "number",
      "default": 3
    },
    "backgroundColor": {
      "type": "string",
      "default": "#7B1FA2"
    },
    "accentColor": {
      "type": "string",
      "default": "#F5C518"
    },
    "showBreadcrumb": {
      "type": "boolean",
      "default": true
    },
    "showCta": {
      "type": "boolean",
      "default": true
    },
    "showPostImages": {
      "type": "boolean",
      "default": true
    }
  }
}