{
  "apiVersion": 3,
  "name": "mytheme/hero",
  "title": "Hero Slider",
  "category": "design",
  "icon": "slides",
  "description": "Full-width hero image slider from a chosen post type. Shows breadcrumb only.",
  "editorScript": "file:./build/index.js",
  "style": "file:./style.css",
  "render": "file:./render.php",
  "attributes": {
    "selectedPostType": {
      "type": "string",
      "default": "post"
    },
    "slideCount": {
      "type": "number",
      "default": 5
    },
    "breadcrumbLabel": {
      "type": "string",
      "default": ""
    },
    "autoplayDelay": {
      "type": "number",
      "default": 5000
    },
    "sliderHeight": {
      "type": "string",
      "default": "420px"
    },
    "overlayOpacity": {
      "type": "number",
      "default": 35
    }
  }
}